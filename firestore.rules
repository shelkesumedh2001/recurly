rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if requester is in same household as target user
    function isHouseholdMember(targetUid, requesterUid) {
      let targetUser = get(/databases/$(database)/documents/users/$(targetUid));
      let requesterUser = get(/databases/$(database)/documents/users/$(requesterUid));
      return targetUser.data.householdId != null
        && targetUser.data.householdId == requesterUser.data.householdId;
    }

    // Users: owner has full access; household members can update profile (for disband cleanup)
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      // Allow household member to clear householdId (disband propagation)
      allow update: if request.auth != null
        && isHouseholdMember(uid, request.auth.uid);

      // Subscriptions: owner has full access, household members can read visible + update/delete splits
      match /subscriptions/{subId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
        allow read: if request.auth != null
          && isHouseholdMember(uid, request.auth.uid)
          && resource.data.householdVisible == true;
        // Allow household members to update (split acceptance) and delete (split cleanup on disband/leave)
        allow update, delete: if request.auth != null
          && isHouseholdMember(uid, request.auth.uid);
      }

      // Split proposals: partner (recipient) can read and write
      match /split_proposals/{proposalId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
        // Owner can create proposals in partner's subcollection
        allow create: if request.auth != null
          && request.resource.data.ownerUid == request.auth.uid;
        // Household members can delete (cleanup on disband/leave)
        allow delete: if request.auth != null
          && isHouseholdMember(uid, request.auth.uid);
      }
    }

    // Households: reads stay open to any authed user (Option A) because the join
    // flow at household_service.dart reads the household doc BEFORE the caller is a
    // member. Writes are tightly constrained below into three disjoint branches.
    match /households/{householdId} {
      allow read: if request.auth != null;

      // Create: caller must be the creator and sole initial member.
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.members == [request.auth.uid];

      // Update — join flow: a non-member appends themselves, nothing else changes.
      allow update: if request.auth != null
        && !(request.auth.uid in resource.data.members)
        && request.resource.data.members.size() == resource.data.members.size() + 1
        && request.resource.data.members.size() <= 2
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members.hasAll(resource.data.members)
        && request.resource.data.createdBy == resource.data.createdBy;

      // Update — leave flow: a non-creator member removes only themselves.
      allow update: if request.auth != null
        && request.auth.uid in resource.data.members
        && request.auth.uid != resource.data.createdBy
        && request.resource.data.members.size() == resource.data.members.size() - 1
        && !(request.auth.uid in request.resource.data.members)
        && resource.data.members.hasAll(request.resource.data.members)
        && request.resource.data.createdBy == resource.data.createdBy;

      // Update — creator refresh: creator rewrites non-membership fields only.
      allow update: if request.auth != null
        && request.auth.uid == resource.data.createdBy
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.members == resource.data.members;

      // Delete: creator only (disband / account deletion).
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.createdBy;
    }

    // Invites: reads stay open so any authed user with a code can look it up.
    // No `update` path — refresh is delete + create. Default-deny blocks squatting.
    match /invites/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.createdBy;
    }
  }
}
